**/bin/
**/obj/
.vs/
.idea/
*.user
*.suo

# Local game content never belongs in the repository.
/Games/*
!/Games/README.md
!/Games/Nintendo/
!/Games/SuperNintendo/
/Games/Nintendo/*
!/Games/Nintendo/README.md
/Games/SuperNintendo/*
!/Games/SuperNintendo/README.md

# Accuracy-test ROMs are installed locally because their redistribution terms vary.
/tests/PixelDeck.App.Tests/TestRoms/*
!/tests/PixelDeck.App.Tests/TestRoms/README.md

# Local emulator captures are diagnostic output. Existing checked-in reference
# captures remain tracked, but new files in this folder stay local.
/artifacts/snes-audit/*
